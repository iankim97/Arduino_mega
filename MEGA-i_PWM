#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

// PCA9685 객체 생성
Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(0x40);

// [설정 변수] 여기에 0, 25, 50, 75, 90 중 원하는 숫자를 넣으세요.
int targetPercent = 75; 

// 드라이버 910mA 기준 700mA 제한값 (약 77%)
const int MAX_SAFE_VALUE = 3150; 

void setup() {
  Serial.begin(115200);
  Serial.println("PCA9685 Scope Test Mode");

  pwm.begin();
  pwm.setPWMFreq(1000); // 스코프에서 관측하기 좋은 1kHz 설정

  // 초기화: 모든 채널 끔
  for(int i=0; i<16; i++) pwm.setPWM(i, 0, 0);
}

void loop() {
  // 입력된 퍼센트를 PWM 값으로 변환 (0~100% -> 0~3150)
  // 만약 700mA 제한 없이 910mA 풀 출력을 보고 싶다면 3150 대신 4095 사용
  int pwmValue = map(targetPercent, 0, 100, 0, MAX_SAFE_VALUE);

  // 0번 포트(첫 번째 채널)로 출력
  pwm.setPWM(0, 0, pwmValue);

  // 시리얼 모니터 출력 (확인용)
  Serial.print("Target: "); Serial.print(targetPercent);
  Serial.print("%  |  PWM Value: "); Serial.println(pwmValue);

  delay(1000); // 1초마다 갱신
}
